# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/workify?retryWrites=true&w=majority

# Session secret (use a long random string in production)
SESSION_SECRET=change-this-to-a-very-long-random-secret

# Cloudinary (for avatar & gallery image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Set to production on Vercel
NODE_ENV=production
